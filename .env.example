# Copy this file to .env and fill in your own values.

# Ollama model to use for responses. Swap between models just by changing this
# line and running `ollama pull <model>` - no code changes needed.
#   Small/fast test model: llama3.2:3b
#   Full uncensored model (the "real" default for this project): taozhiyuai/llama-3-8b-lexi-uncensored:f16
OLLAMA_MODEL=taozhiyuai/llama-3-8b-lexi-uncensored:f16

# Ollama server URL (default is fine for a local install)
OLLAMA_HOST=http://localhost:11434

# Path to your custom-trained "Hey Zhora" openWakeWord .onnx model file.
# Required until this is set (see README for training instructions) - there is
# no pretrained "Zhora" wake word, and no other assistant's wake word is used
# as a placeholder here.
WAKE_WORD_MODEL_PATH=

# Only used as a fallback if WAKE_WORD_MODEL_PATH is unset - a bundled
# openWakeWord pretrained model name, for testing the pipeline before your
# custom model is ready. Leave blank unless you're doing that.
WAKE_WORD_NAME=

# Detection sensitivity (0-1). Lower = more sensitive / more false positives.
WAKE_WORD_THRESHOLD=0.5

# Whether responses are spoken automatically. When off, TTS is still available
# on-demand per message in the desktop app. All of these are also editable
# from the desktop app's Settings panel, which writes back to this file.
AUTO_SPEAK_RESPONSES=true

# What the desktop window's close (X) button does:
#   ask  - show a dialog the first time, remember the choice (default)
#   tray - always minimize to the tray, keep listening in the background
#   quit - always exit Zhora fully
CLOSE_BEHAVIOR=ask
