# Copy this file to .env and fill in your own values.

# Ollama model to use for responses. Swap between models just by changing this
# line and running `ollama pull <model>` - no code changes needed.
#   Small/fast test model: llama3.2:3b
#   Full uncensored model (the "real" default for this project): taozhiyuai/llama-3-8b-lexi-uncensored:f16
OLLAMA_MODEL=taozhiyuai/llama-3-8b-lexi-uncensored:f16

# Ollama server URL (default is fine for a local install)
OLLAMA_HOST=http://localhost:11434

# Require explicit y/N approval in the terminal before any tool call (web
# search, calculator, etc.) executes. Defaults to true - fail closed, since
# this project intentionally runs an unrestricted model with no other safety
# net. Set to false only once you fully trust the toolset you've wired in.
REQUIRE_TOOL_CONFIRMATION=true

# openWakeWord wake word to listen for. Use a bundled pretrained model name
# (e.g. hey_jarvis_v0.1, alexa_v0.1, hey_mycroft_v0.1) until a custom
# "Hey Zora" model is trained (see README for training instructions).
WAKE_WORD_NAME=hey_jarvis_v0.1

# Optional: path to a custom-trained .onnx/.tflite wake word model file.
# Leave blank to use the pretrained WAKE_WORD_NAME above.
WAKE_WORD_MODEL_PATH=

# Detection sensitivity (0-1). Lower = more sensitive / more false positives.
WAKE_WORD_THRESHOLD=0.5
