# Copy this file to .env and fill in your own values.

# Ollama model to use for responses. Swap between models just by changing this
# line and running `ollama pull <model>` - no code changes needed.
#   Small/fast test model: llama3.2:3b
#   Full uncensored model (the "real" default for this project): taozhiyuai/llama-3-8b-lexi-uncensored:f16
OLLAMA_MODEL=taozhiyuai/llama-3-8b-lexi-uncensored:f16

# Ollama server URL (default is fine for a local install)
OLLAMA_HOST=http://localhost:11434

# Speech-to-text backend:
#   vosk   - fully offline, no network calls (default). Needs a model
#            downloaded once - see README setup instructions.
#   google - Google's free Web Speech API. Needs internet, no model download.
STT_ENGINE=vosk

# Only used by the vosk backend. Leave blank to use the default path
# (data/models/vosk-model-small-en-us-0.15) - only set this if you downloaded
# a different Vosk model or put it somewhere else.
VOSK_MODEL_PATH=

# How much trailing silence (seconds) after you stop talking ends a voice
# recording. Lower feels snappier but risks cutting off speech during a
# natural mid-sentence pause; too low picks up room noise as "still talking"
# and stops recognizing silence at all.
STT_SILENCE_DURATION=0.8

# int16 mic amplitude above which audio counts as speech, not silence. Raise
# this if a noisy room is preventing silence from ever being detected
# (recording would then run until the 15s hard cap every time); lower it if
# quiet speech isn't being picked up as "started talking".
STT_SILENCE_THRESHOLD=500

# Text-to-speech voice: a local Piper .onnx model, fully offline. Leave blank
# to use the default path (data/models/piper/en_US-lessac-medium.onnx) -
# only set this if you downloaded a different Piper voice or moved it.
PIPER_MODEL_PATH=

# Optional TTS overrides, also editable from the desktop app's Settings
# panel. VOICE_ID is a Piper .onnx path (defaults to PIPER_MODEL_PATH above);
# VOICE_RATE is Piper's length_scale (1.0 = normal, lower = faster, higher =
# slower); VOICE_VOLUME is 0.0-1.0. Leave all blank to use Piper's defaults.
VOICE_ID=
VOICE_RATE=
VOICE_VOLUME=

# Path to your custom-trained "Hey Zhora" openWakeWord .onnx model file.
# Required until this is set (see README for training instructions) - there is
# no pretrained "Zhora" wake word, and no other assistant's wake word is used
# as a placeholder here.
WAKE_WORD_MODEL_PATH=

# Only used as a fallback if WAKE_WORD_MODEL_PATH is unset - a bundled
# openWakeWord pretrained model name, for testing the pipeline before your
# custom model is ready. Leave blank unless you're doing that.
WAKE_WORD_NAME=

# Detection sensitivity (0-1). Lower = more sensitive / more false positives.
WAKE_WORD_THRESHOLD=0.5

# Whether responses are spoken automatically. When off, TTS is still available
# on-demand per message in the desktop app. All of these are also editable
# from the desktop app's Settings panel, which writes back to this file.
AUTO_SPEAK_RESPONSES=true

# What the desktop window's close (X) button does:
#   ask  - show a dialog the first time, remember the choice (default)
#   tray - always minimize to the tray, keep listening in the background
#   quit - always exit Zhora fully
CLOSE_BEHAVIOR=ask
